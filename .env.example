# ──────────────────────────────────────────────────────────────────────────
# Personal AI Assistant — environment / bootstrap secrets
# Copy to `.env` (chmod 600) and fill in. NEVER commit the real .env.
# These are the only secrets that live outside the SQLite DB.
# ──────────────────────────────────────────────────────────────────────────

# Master encryption key. Used to AES-GCM encrypt MCP credentials stored in the
# DB. 32 bytes, base64-encoded. Generate one with:
#   openssl rand -base64 32
# Losing this makes encrypted DB rows unrecoverable. Required once any secret
# is stored; recommended to set from day one.
MASTER_KEY=

# Portal session cookie signing key (HMAC). 32+ bytes, base64-encoded.
#   openssl rand -base64 32
# If left blank in dev, the app generates one and persists it to data/.session_key.
# In production, set this explicitly so sessions survive across hosts.
SESSION_KEY=

# HTTP listen address for the web portal.
HTTP_ADDR=:8080

# Path to the SQLite database file.
# Native dev default below; in Docker this is /data/app.db on a named volume.
DB_PATH=./data/app.db

# Path to the `claude` CLI used by the claude-headless runtime.
CLAUDE_BIN=claude

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Environment: dev | prod  (dev enables conveniences like session-key autogen)
APP_ENV=dev

# Telegram bot token (from @BotFather; leave blank to keep Telegram disabled).
TELEGRAM_BOT_TOKEN=

# Enable the runtime's scoped built-in tools (Read/Glob/Grep/Bash/Write/Edit) so
# skills with scripts can execute. true | false. Defaults ON in prod, OFF for
# native dev. Set explicitly to override.
ALLOW_AGENT_TOOLS=

# Per-user OS isolation for the agent's host tools. true | false. When on
# (default in prod), the orchestrator runs as root and drops each agent run to a
# distinct unprivileged uid so one user's bash/read can't touch another user's
# workspace or the database. Needs root on Linux (the container has it); on
# native dev / non-root it auto-disables with a warning. Set false to keep the
# app running as a single unprivileged uid (no per-user isolation).
AGENT_ISOLATION=
# Base for per-user run uids/gids: user N runs as AGENT_UID_BASE+N. Default 20000.
AGENT_UID_BASE=
# Shared supplementary gid that lets every run read the claude.ai credentials dir
# while staying unable to read the root-owned DB. Default 10002.
AGENT_CRED_GID=

# Docker image to run (used by docker-compose when pulling a pre-built image from
# a registry instead of building locally). Defaults to a local build.
# On a VPS, set this to the exact reference you pushed, e.g.
#   IMAGE=your-dockerhub-user/samwise:latest
#   IMAGE=us-central1-docker.pkg.dev/my-proj/apps/samwise:latest
IMAGE=samwise:latest

# ── HTTPS via the bundled nginx + certbot reverse proxy (Let's Encrypt) ────
# Only used with the "tls" compose profile. First-time setup:
#   sh nginx/init-letsencrypt.sh        # gets the cert
#   docker compose --profile tls up -d  # serves + auto-renews
# Domain nginx serves and certbot gets a cert for. Must have a DNS A record
# pointing at this VPS. Leave blank to keep the portal loopback-only (no TLS).
SITE_ADDRESS=
# Email for the Let's Encrypt account (expiry/renewal notices). Optional but
# recommended; blank registers without an email.
CERTBOT_EMAIL=
# Set to 1 to use Let's Encrypt's staging CA while testing (avoids hitting the
# strict rate limits of the production CA). Leave blank/0 for real certs.
CERTBOT_STAGING=
# Set true when running behind the nginx proxy so the app reads the real client
# IP from X-Forwarded-For (login rate-limiting/audit). Leave false otherwise —
# enabling it while directly reachable would let clients spoof their IP.
TRUST_PROXY=

# ── Plain-HTTP mode (the "http" compose profile, no TLS) ───────────────────
# To serve the portal on port 80 over plain HTTP (e.g. behind a VPN/Tailscale,
# or for testing):  docker compose --profile http up -d
# Set COOKIE_SECURE=false so the session cookie is sent over http:// (otherwise
# login silently fails), and TRUST_PROXY=true (above) since nginx is in front.
# Leave COOKIE_SECURE blank for the secure default (on in prod) when using HTTPS.
COOKIE_SECURE=
