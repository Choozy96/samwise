# ──────────────────────────────────────────────────────────────────────────
# Personal AI Assistant — environment / bootstrap secrets
# Copy to `.env` (chmod 600) and fill in. NEVER commit the real .env.
# These are the only secrets that live outside the SQLite DB (spec §10.2).
# ──────────────────────────────────────────────────────────────────────────

# Master encryption key. Used to AES-GCM encrypt MCP credentials stored in the
# DB. 32 bytes, base64-encoded. Generate one with:
#   openssl rand -base64 32
# Losing this makes encrypted DB rows unrecoverable. Required once any secret
# is stored; recommended to set from day one.
MASTER_KEY=

# Portal session cookie signing key (HMAC). 32+ bytes, base64-encoded.
#   openssl rand -base64 32
# If left blank in dev, the app generates one and persists it to data/.session_key.
# In production, set this explicitly so sessions survive across hosts.
SESSION_KEY=

# HTTP listen address for the web portal.
HTTP_ADDR=:8080

# Path to the SQLite database file (spec §6: db.path).
# Native dev default below; in Docker this is /data/app.db on a named volume.
DB_PATH=./data/app.db

# Path to the `claude` CLI used by the claude-headless runtime.
CLAUDE_BIN=claude

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Environment: dev | prod  (dev enables conveniences like session-key autogen)
APP_ENV=dev

# Telegram bot token (from @BotFather; leave blank to keep Telegram disabled).
TELEGRAM_BOT_TOKEN=

# Enable the runtime's scoped built-in tools (Read/Glob/Grep/Bash/Write/Edit) so
# skills with scripts can execute. true | false. Defaults ON in prod (the
# container is the sandbox boundary), OFF for native dev. Set explicitly to
# override.
ALLOW_AGENT_TOOLS=

# Docker image to run (used by docker-compose when pulling a pre-built image from
# a registry instead of building locally). Defaults to a local build.
# On a VPS, set this to the exact reference you pushed, e.g.
#   IMAGE=your-dockerhub-user/samwise:latest
#   IMAGE=us-central1-docker.pkg.dev/my-proj/apps/samwise:latest
IMAGE=samwise:latest
